#################################################################
#    vocabulary body
#################################################################

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoAgibilitaImmobile/N> a skos:Concept,
        :TipoStatoDiAgibilitaImmobile ;
    skos:prefLabel "NON AGIBILE"@it,
        "UNINHABITABLE"@en ;
    skos:definition "Immobile non agibile"@it,
        "Property uninhabitable"@en ;
    dct:identifier "N" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita> ;
    skos:notation "N" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoAgibilitaImmobile/R> a skos:Concept,
        :TipoStatoDiAgibilitaImmobile ;
    skos:prefLabel "IN CORSO DI RISTRUTTURAZIONE"@it,
        "UNDER RENOVATION"@en ;
    skos:definition "Immobile in corso di ristrutturazione"@it,
        "Property under renovation"@en ;
    dct:identifier "R" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita> ;
    skos:notation "R" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoAgibilitaImmobile/A> a skos:Concept,
        :TipoStatoDiAgibilitaImmobile ;
    skos:prefLabel "AGIBILE"@it,
        "HABITABLE"@en ;
    skos:definition "Immobile agibile"@it,
        "Property habitable"@en ;
    dct:identifier "A" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita> ;
    skos:notation "A" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoAgibilitaImmobile/ND> a skos:Concept,
        :TipoStatoDiAgibilitaImmobile ;
    skos:prefLabel "NON DEFINITO"@it,
        "NOT DEFINED"@en ;
    skos:definition "Stato di agibilità non definito"@it,
        "Habitability status not defined"@en ;
    dct:identifier "ND" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita> ;
    skos:notation "ND" .
