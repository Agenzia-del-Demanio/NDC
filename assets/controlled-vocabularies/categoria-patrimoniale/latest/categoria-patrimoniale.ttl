<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> a adms:Asset,
        dcatapit:Dataset,
        skos:ConceptScheme ;
    rdfs:label "Controlled Vocabulary for Asset Categories"@en,
