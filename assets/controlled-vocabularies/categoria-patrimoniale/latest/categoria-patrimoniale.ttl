#################################################################
#    vocabulary body
#################################################################

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23A1> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "BENI DISPONIBILI"@it,
        "AVAILABLE ASSETS"@en ;
    skos:definition "Beni appartenenti al patrimonio dello Stato suscettibili di alienazione o utilizzazione economica secondo le disposizioni del Codice civile e della normativa patrimoniale."@it,
        "Assets belonging to the State's patrimony that can be alienated or economically exploited according to the provisions of the Civil Code and patrimonial regulations."@en ;
    dct:identifier "23A1" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "23A1" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23A4> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "MINIERE E RELATIVE PERTINENZE"@it,
        "MINES AND RELATED APPURTENANCES"@en ;
    skos:definition "Beni patrimoniali costituiti da giacimenti minerari e dalle relative pertinenze fisiche e infrastrutturali, disciplinati dalla normativa mineraria."@it,
        "Patrimonial assets consisting of mineral deposits and their related physical and infrastructural appurtenances, governed by mining regulations."@en ;
    dct:identifier "23A4" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "23A4" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23A5> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "BENI ASSEGNATI IN USO GOVERNATIVO"@it,
        "ASSETS ASSIGNED FOR GOVERNMENTAL USE"@en ;
    skos:definition "Beni appartenenti allo Stato e assegnati in uso gratuito o oneroso a pubbliche amministrazioni per finalità istituzionali."@it,
        "Assets belonging to the State and assigned for free or paid use to public administrations for institutional purposes."@en ;
    dct:identifier "23A5" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "23A5" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23A6> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "BENI NON DISPONIBILI"@it,
        "UNAVAILABLE ASSETS"@en ;
    skos:definition "Beni del patrimonio dello Stato non alienabili, in quanto destinati a un pubblico servizio o a un uso di pubblica utilità, pur non appartenendo al demanio necessario."@it,
        "Assets of the State's patrimony that cannot be alienated, as they are intended for public service or public utility use, although not belonging to the necessary public domain."@en ;
    dct:identifier "23A6" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "23A6" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23B2> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "BENI SU CUI GRAVANO DIR. REALI A FAVORE TERZI"@it,
        "ASSETS ENCUMBERED BY REAL RIGHTS IN FAVOR OF THIRD PARTIES"@en ;
    skos:definition "Beni patrimoniali dello Stato gravati da diritti reali (usufrutto, servitù, enfiteusi, ecc.) costituiti a favore di soggetti diversi dallo Stato."@it,
        "State patrimonial assets encumbered by real rights (usufruct, easement, emphyteusis, etc.) established in favor of entities other than the State."@en ;
    dct:identifier "23B2" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "23B2" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23C3> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "DIRITTI REALI SU BENI PATRIMONIALI"@it,
        "REAL RIGHTS ON PATRIMONIAL ASSETS"@en ;
    skos:definition "Diritti reali attivi spettanti allo Stato su beni di proprietà altrui, aventi natura patrimoniale (es. servitù, enfiteusi attiva, usufrutto)."@it,
        "Active real rights belonging to the State on assets owned by others, having a patrimonial nature (e.g., easement, active emphyteusis, usufruct)."@en ;
    dct:identifier "23C3" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "23C3" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23C3C> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "DIR. REALI SU BENI DI PROPRIETA` DI COMUNI"@it,
        "REAL RIGHTS ON ASSETS OWNED BY MUNICIPALITIES"@en ;
    skos:definition "Diritti reali spettanti allo Stato su beni appartenenti a enti comunali."@it,
        "Real rights belonging to the State on assets owned by municipal entities."@en ;
    dct:identifier "23C3C" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "23C3C" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23C3P> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "DIR. REALI SU BENI DI PROPRIETA` DI PROVINCE"@it,
        "REAL RIGHTS ON ASSETS OWNED BY PROVINCES"@en ;
    skos:definition "Diritti reali spettanti allo Stato su beni appartenenti a enti provinciali."@it,
        "Real rights belonging to the State on assets owned by provincial entities."@en ;
    dct:identifier "23C3P" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "23C3P" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23C3R> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "DIR. REALI SU BENI DI PROPRIETA` DI REGIONI"@it,
        "REAL RIGHTS ON ASSETS OWNED BY REGIONS"@en ;
    skos:definition "Diritti reali spettanti allo Stato su beni appartenenti a enti regionali."@it,
        "Real rights belonging to the State on assets owned by regional entities."@en ;
    dct:identifier "23C3R" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "23C3R" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23C3T> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "DIR. REALI SU BENI DI PROPRIETA` DI TERZI"@it,
        "REAL RIGHTS ON ASSETS OWNED BY THIRD PARTIES"@en ;
    skos:definition "Diritti reali spettanti allo Stato su beni appartenenti a soggetti terzi."@it,
        "Real rights belonging to the State on assets owned by third parties."@en ;
    dct:identifier "23C3T" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "23C3T" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/NA> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "NON APPLICABILE"@it,
        "NOT APPLICABLE"@en ;
    skos:definition "Non applicabile."@it,
        "Not applicable."@en ;
    dct:identifier "NA" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "NA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/NDEF> a skos:Concept,
        :TipoCategoriaPatrimonialeImmobile ;
    skos:prefLabel "NON DEFINITA"@it,
        "NOT DEFINED"@en ;
    skos:definition "Non definita."@it,
        "Not defined."@en ;
    dct:identifier "NDEF" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    skos:notation "NDEF" .
