        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/NA> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/NDEF> ;
    skos:notation "Controlled Vocabulary for Asset Categories"@en,
        "Vocabolario Controllato delle Categorie Patrimoniali"@it ;
    xkos:numberOfLevels "1" .


