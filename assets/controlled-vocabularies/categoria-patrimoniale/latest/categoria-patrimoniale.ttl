        "Vocabolario Controllato delle Categorie Patrimoniali"@it ;
    owl:versionInfo "Versione 0.1"@it ;
    rdfs:isDefinedBy <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale> ;
    adms:representationTechnique <http://purl.org/adms/representationtechnique/SKOS> ;
    dcat:contactPoint <https://w3id.org/italia/data/contact-point/ISTAT-NDC> ;
    dcat:distribution <https://w3id.org/italia/real-estate/data/StateProperty/distribution/categoria-patrimoniale-CSV>,
