        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/categoria-patrimoniale-RDF-Turtle>,
        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/categoria-patrimoniale-XSLX> ;
    dcat:keyword "Categoria Patrimoniale"@it,
        "Asset Category"@en ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
    dct:creator <https://w3id.org/italia/data/public-organization/ISTAT> ;
    dct:description "La categoria patrimoniale rappresenta la classificazione amministrativo-contabile dei beni immobili e dei diritti reali gestiti dall’Agenzia del Demanio, finalizzata a identificarne la natura giuridica e la modalità di appartenenza o gestione nell’ambito del patrimonio dello Stato. Essa consente di distinguere i beni demaniali e patrimoniali in base alla loro disponibilità, destinazione, o all’esistenza di diritti reali a favore o a carico di soggetti terzi."@it,
        "The asset category represents the administrative and accounting classification of real estate properties and real rights managed by the State Property Agency, aimed at identifying their legal nature and the way in which they are owned or managed within the State’s assets. It makes it possible to distinguish between demanial and patrimonial assets on the basis of their availability, intended use, or the existence of real rights in favor of or encumbering third parties."@en ;
    dct:identifier "https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/categoria-patrimoniale" ;
    dct:issued "2026-03-18"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/ITA> ;
    dct:modified "2026-03-18"^^xsd:date ;
    dct:publisher <https://w3id.org/italia/data/public-organization/PCM-1RSIZZ> ;
    dct:rightsHolder <https://w3id.org/italia/data/public-organization/agd> ;
    dct:subject <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
    dct:title "Controlled Vocabulary for Asset Categories"@en,
        "Vocabolario Controllato delle Categorie Patrimoniali"@it ;
    dct:type <http://purl.org/adms/assettype/CodeList> ;
	dct:temporal "Dal 2026" ;
	dct:subject <http://publications.europa.eu/resource/authority/data-theme/ECON> ;
    ndc:keyConcept "categoria-patrimoniale" ;
    skos:hasTopConcept <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23A1> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23A4> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23A5> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoCategoriaPatrimonialeImmobile/23A6> ,
