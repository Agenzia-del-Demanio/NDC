<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita> a adms:Asset,
        dcatapit:Dataset,
        skos:ConceptScheme ;
    rdfs:label "Habitability Status controlled vocabulary"@en,
        "Vocabolario Controllato degli Stati di Agibilità"@it ;
    skos:prefLabel "Habitability Status controlled vocabulary"@en,
        "Vocabolario Controllato degli Stati di Agibilità"@it ;
    rdfs:comment "Habitability Status controlled vocabulary"@en,
        "Vocabolario Controllato degli Stati di Agibilità"@it ;
    owl:versionInfo "Versione 0.1"@it ;
    rdfs:isDefinedBy <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita> ;
    adms:representationTechnique <http://purl.org/adms/representationtechnique/SKOS> ;
    dcat:contactPoint <https://w3id.org/italia/data/contact-point/ISTAT-NDC> ;
    dcat:distribution <https://w3id.org/italia/real-estate/data/StateProperty/distribution/stato-di-agibilita-CSV>,
        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/stato-di-agibilita-JSON-LD>,
        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/stato-di-agibilita-RDF-Turtle>,
        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/stato-di-agibilita-XSLX> ;
    dcat:keyword "Stato di Agibilità"@it,
        "Habitability Status"@en ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
    dct:creator <https://w3id.org/italia/data/public-organization/ISTAT> ;
    dct:description "Lo stato di agibilità rappresenta la condizione tecnica e normativa di un immobile in relazione alla sua idoneità all'uso e all'occupazione. Tale classificazione identifica se l'immobile può essere utilizzato in sicurezza per la destinazione d'uso prevista, sulla base di valutazioni strutturali, impiantistiche e igienico-sanitarie, nonché della conformità alle normative vigenti in materia edilizia e di sicurezza."@it,
        "The habitability status represents the technical and regulatory condition of a property in relation to its suitability for use and occupation. This classification identifies whether the property can be safely used for its intended purpose, based on structural, plant and health assessments, as well as compliance with current building and safety regulations."@en ;
    dct:identifier "https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita" ;
    dct:issued "2026-03-18"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/ITA> ;
    dct:modified "2026-03-18"^^xsd:date ;
    dct:publisher <https://w3id.org/italia/data/public-organization/PCM-1RSIZZ> ;
    dct:rightsHolder <https://w3id.org/italia/data/public-organization/agd> ;
    dct:subject <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
    dct:title "Habitability Status controlled vocabulary"@en,
        "Vocabolario Controllato degli Stati di Agibilità"@it ;
    dct:type <http://purl.org/adms/assettype/CodeList> ;
	dct:temporal "Dal 2026" ;
	dct:subject <http://publications.europa.eu/resource/authority/data-theme/ECON> ;
    ndc:keyConcept "stato-di-agibilita" ;
    skos:hasTopConcept <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoAgibilitaImmobile/N> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoAgibilitaImmobile/R> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoAgibilitaImmobile/A> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoAgibilitaImmobile/ND> ;
    skos:notation "Habitability Status controlled vocabulary"@en,
        "Vocabolario Controllato degli Stati di Agibilità"@it ;
    xkos:numberOfLevels "1" .


