    adms:representationTechnique <http://purl.org/adms/representationtechnique/SKOS> ;
    dcat:contactPoint <https://w3id.org/italia/data/contact-point/ISTAT-NDC> ;
    dcat:distribution <https://w3id.org/italia/real-estate/data/StateProperty/distribution/tipo-di-accesso-CSV>,
        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/tipo-di-accesso-JSON-LD>,
        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/tipo-di-accesso-RDF-Turtle>,
        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/tipo-di-accesso-XSLX> ;
    dcat:keyword "Tipo di Accesso"@it,
        "Access Type"@en ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
    dct:creator <https://w3id.org/italia/data/public-organization/ISTAT> ;
    dct:description "Il tipo di accesso rappresenta la modalità con cui è consentito l'ingresso e l'utilizzo degli immobili gestiti dall'Agenzia del Demanio. Tale classificazione identifica il regime di accessibilità fisica e giuridica, distinguendo tra accesso pubblico, riservato, regolamentato o condizionato, in conformità alle normative sulla fruizione del patrimonio pubblico e alle esigenze di sicurezza, tutela e gestione degli spazi."@it,
        "The access type represents the manner in which entry and use of properties managed by the State Property Agency is permitted. This classification identifies the physical and legal accessibility regime, distinguishing between public, reserved, regulated or conditional access, in accordance with regulations on the use of public assets and security, protection and space management needs."@en ;
    dct:identifier "https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso" ;
    dct:issued "2026-03-18"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/ITA> ;
    dct:modified "2026-03-18"^^xsd:date ;
    dct:publisher <https://w3id.org/italia/data/public-organization/PCM-1RSIZZ> ;
    dct:rightsHolder <https://w3id.org/italia/data/public-organization/agd> ;
    dct:subject <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
    dct:title "Access Types controlled vocabulary"@en,
        "Vocabolario Controllato dei Tipi di Accesso"@it ;
    dct:type <http://purl.org/adms/assettype/CodeList> ;
	dct:temporal "Dal 2026" ;
	dct:subject <http://publications.europa.eu/resource/authority/data-theme/ECON> ;
    ndc:keyConcept "tipo-di-accesso" ;
    skos:hasTopConcept <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoAccessoImmobile/01> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoAccessoImmobile/02> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoAccessoImmobile/03> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoAccessoImmobile/04> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoAccessoImmobile/05> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoAccessoImmobile/06> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoAccessoImmobile/07> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoAccessoImmobile/08> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoAccessoImmobile/ND> ,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoAccessoImmobile/NA> ;
    skos:notation "Access Types controlled vocabulary"@en,
        "Vocabolario Controllato dei Tipi di Accesso"@it ;
    xkos:numberOfLevels "1" .


