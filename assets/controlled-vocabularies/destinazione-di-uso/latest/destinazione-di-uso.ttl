    dcat:keyword "Destinazione d'Uso"@it,
        "Intended Use"@en ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
    dct:creator <https://w3id.org/italia/data/public-organization/ISTAT> ;
    dct:description "La destinazione d'uso rappresenta la classificazione funzionale degli immobili gestiti dall'Agenzia del Demanio, indicando la tipologia di utilizzo prevalente o previsto per ciascun bene. Tale classificazione consente di identificare l'impiego effettivo o potenziale degli spazi, distinguendo tra destinazioni residenziali, commerciali, istituzionali, culturali o di altra natura, in conformità alla normativa urbanistica e alle finalità pubbliche."@it,
        "The intended use represents the functional classification of properties managed by the State Property Agency, indicating the main or planned type of use for each asset. This classification allows for the identification of the actual or potential use of spaces, distinguishing between residential, commercial, institutional, cultural, or other uses, in accordance with urban planning regulations and public purposes."@en ;
    dct:identifier "https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso" ;
    dct:issued "2026-03-18"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/ITA> ;
    dct:modified "2026-03-18"^^xsd:date ;
    dct:publisher <https://w3id.org/italia/data/public-organization/PCM-1RSIZZ> ;
    dct:rightsHolder <https://w3id.org/italia/data/public-organization/agd> ;
    dct:subject <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
    dct:title "Intended Use controlled vocabulary"@en,
        "Vocabolario Controllato delle Destinazioni d'Uso"@it ;
    dct:type <http://purl.org/adms/assettype/CodeList> ;
	dct:temporal "Dal 2026" ;
	dct:subject <http://publications.europa.eu/resource/authority/data-theme/ECON> ;
